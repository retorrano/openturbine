{
    "version": "1.0",
    "name": "Default Simulation Configuration",
    "description": "Master configuration file that loads all module defaults",
    "modules": {
        "turbine": "configs/defaults/turbine.json",
        "aerodynamics": "configs/defaults/aerodynamics.json",
        "structural": "configs/defaults/structural.json",
        "control": "configs/defaults/control.json",
        "environment": "configs/defaults/environment.json"
    },
    "simulation": {
        "type": {
            "value": "steady_state",
            "description": "Type of simulation to run",
            "options": ["steady_state", "time_domain", "fatigue", "modal"],
            "ui_group": "Simulation"
        },
        "duration": {
            "value": 600.0,
            "unit": "s",
            "description": "Simulation duration for time-domain analysis",
            "min": 1.0,
            "max": 3600.0,
            "ui_group": "Simulation"
        },
        "time_step": {
            "value": 0.01,
            "unit": "s",
            "description": "Simulation time step",
            "min": 0.0001,
            "max": 1.0,
            "ui_group": "Simulation"
        },
        "wind_speed_sweep": {
            "enabled": {
                "value": true,
                "description": "Enable parametric wind speed sweep",
                "ui_group": "Parametric Sweep"
            },
            "start_speed": {
                "value": 3.0,
                "unit": "m/s",
                "description": "Starting wind speed for sweep",
                "min": 0.0,
                "max": 20.0,
                "ui_group": "Parametric Sweep"
            },
            "end_speed": {
                "value": 25.0,
                "unit": "m/s",
                "description": "Ending wind speed for sweep",
                "min": 10.0,
                "max": 40.0,
                "ui_group": "Parametric Sweep"
            },
            "step_size": {
                "value": 1.0,
                "unit": "m/s",
                "description": "Wind speed step size for sweep",
                "min": 0.1,
                "max": 5.0,
                "ui_group": "Parametric Sweep"
            }
        },
        "output": {
            "save_results": {
                "value": true,
                "description": "Save simulation results to file",
                "ui_group": "Output"
            },
            "results_directory": {
                "value": "results",
                "description": "Directory for saving results",
                "ui_group": "Output"
            },
            "export_formats": {
                "value": ["csv", "json"],
                "description": "Output file formats",
                "options": ["csv", "json", "excel", "hdf5"],
                "ui_group": "Output"
            }
        }
    },
    "visualization": {
        "animation": {
            "enabled": {
                "value": true,
                "description": "Enable real-time animation",
                "ui_group": "Animation"
            },
            "frame_rate": {
                "value": 30,
                "unit": "fps",
                "description": "Target animation frame rate",
                "min": 10,
                "max": 60,
                "ui_group": "Animation"
            },
            "quality": {
                "value": "medium",
                "description": "Rendering quality level",
                "options": ["low", "medium", "high"],
                "ui_group": "Animation"
            }
        },
        "charts": {
            "update_rate": {
                "value": 10,
                "unit": "fps",
                "description": "Chart update rate",
                "min": 1,
                "max": 30,
                "ui_group": "Charts"
            },
            "window_size": {
                "value": 100,
                "unit": "samples",
                "description": "Rolling window size for time-series plots",
                "min": 10,
                "max": 1000,
                "ui_group": "Charts"
            }
        }
    }
}
